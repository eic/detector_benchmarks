import os

SIMOUTDIR="sim_output/lowq2_rates/"
ANALYSISDIR=SIMOUTDIR+"analysis/"
GETaLM_PATH="/home/simong/Generators/GETaLM"

##########################################################################################
### Rules for checking the reconstruction of the electron momentum
##########################################################################################

# Filter LowQ2 events from xrootd server - Using the acceptance events didn't work
# ToDo: Do a proper investigation into how the feature to target mapping isn't unique
rule generate_Bremsstrahlung_events:
    input:
        warmup="warmup/epic_ip6_extended.edm4hep.root",
        # xml=lambda wildcards:
        steeringCard=lambda wildcards: workflow.source_path(f"lumi_{wildcards.BEAMENERGY}.ini"),
        GETaLM_EXE=GETaLM_PATH+"/GETaLM"
    output:
        SIMOUTDIR+"brems_{BEAMENERGY}.hepmc3.tree.root",
    shell:
        """
        {input.GETaLM_EXE} {input.steeringCard}
        """

rule afterburner_Bremsstrahlung_events:
    input:
        data=SIMOUTDIR+"brems_{BEAMENERGY}.hepmc3.tree.root",
        warmup="warmup/epic_ip6_extended.edm4hep.root",
    output:
        SIMOUTDIR+"brems_{BEAMENERGY}.ab.hepmc3.tree.root",
    shell:
        """
        abconv --preset 0 --out-format treeroot --plot-off --output temp {input.data}
        mv temp.hepmc.root {output}        
        """

rule simulate_Bremsstrahlung_events:
    input:
        events=SIMOUTDIR+"brems_{BEAMENERGY}.ab.hepmc3.tree.root",
        warmup="warmup/epic_ip6_extended.edm4hep.root",
        xml=lambda wildcards: workflow.source_path(f"epic_ip6_extended_{wildcards.BEAMENERGY}.xml"),
        geometry_lib=find_epic_libraries(),
    output:
        SIMOUTDIR+"brems_{BEAMENERGY}.edm4hep.root",
    shell:
        """
            exec npsim \
            --runType run \
            --random.seed 1 \
            --inputFiles {input.events} \
            --numberOfEvents 10000 \
            --compactFile {input.xml} \
            --printLevel WARNING \
            --outputFile {output} \
            --physics.rangecut 100*m 
        """

rule simulate_QR_events:
    input:
        warmup="warmup/epic_ip6_extended.edm4hep.root",
        data="sim_output/lowq2_reconstruction/lowq2_QR_5GeV_events.hepmc3.root",

rule plot_rates:
    input:
        events=SIMOUTDIR+"{source}_{BEAMENERGY}.edm4hep.root",
        script=workflow.source_path("RunLOWQ2.C"),
        headerBM=workflow.source_path("LOWQ2Benchmarks.h"),
        headerHits=workflow.source_path("LOWQ2hits.h"),
        headerCluster=workflow.source_path("LOWQ2clusters.h"),
        headerAcceptance=workflow.source_path("LOWQ2acceptance.h"),
        headerReconstruction=workflow.source_path("LOWQ2reconstruction.h"),
        headerFunctor=workflow.source_path("functors.h"),
    output:
        ANALYSISDIR+"{source}_{BEAMENERGY}_rates_plots.root",
    params:
        xml=os.getenv("DETECTOR_PATH")+"/epic_ip6_extended.xml",
    shell:
        """
        root -l -b -q '{input.script}("{input.events}", "{output}", "{params.xml}")'
        """